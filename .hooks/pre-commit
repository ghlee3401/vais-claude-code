#!/bin/sh
# VAIS Code — pre-commit hook
# git config core.hooksPath .hooks 으로 활성화
set -e

echo "[VAIS] Running pre-commit checks..."

# ESLint
if command -v npx > /dev/null 2>&1; then
  npx eslint scripts/ lib/ hooks/ --max-warnings=0
  echo "[VAIS] ESLint passed."
fi

# Unit tests
node --test tests/*.test.js
echo "[VAIS] Tests passed."
