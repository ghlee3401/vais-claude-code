# VAIS Code — Environment Variables Template
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# ─── Figma (mui-design-system-import 피처) ────────────────────────────────────
# Personal Access Token: https://www.figma.com/settings → Security → Generate
#   Required scope: "File content" (Read-only)
# 둘 중 어느 변수명이든 인식: FIGMA_PAT 또는 VITE_FIGMA_PAT
FIGMA_PAT=
# Figma file key (URL의 /design/{KEY}/... 부분, ~22자 영숫자)
# Community 파일은 "Open in Figma" 클릭 후 자기 Drafts 의 URL 에서 복사
FIGMA_FILE_KEY=

# Vite-style alias (둘 중 한 쌍만 채워도 됨)
# VITE_FIGMA_PAT=
# VITE_FIGMA_FILE_KEY=

# ─── MUI version pin (선택, default: package.json devDep) ────────────────────
# MUI_VERSION_PIN=6.1.7
