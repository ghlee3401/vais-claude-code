  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "claude-plugin",
    "ai-agents",
    "c-suite",
    "vais"
  ]
}
