{
  "name": "vais-code",
  "version": "0.56.1",
  "description": "Virtual AI C-Suite for software development — Claude Code Plugin",
  "author": "ghlee3401",
  "license": "MIT",
  "claude-plugin": {
    "skills": [
      "skills/vais/SKILL.md"
    ],
    "agents": [
      "agents/"
    ],
    "hooks": [
      "hooks/hooks.json"
    ],
    "outputStyles": "output-styles/vais-default.md"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint scripts/ lib/ hooks/ --max-warnings=0",
