{
  "name": "vais-code",
  "version": "0.64.0",
  "description": "Virtual AI C-Suite for software development — Claude Code Plugin",
  "author": "ghlee3401",
  "license": "MIT",
  "claude-plugin": {
    "skills": [
      "skills/vais/SKILL.md"
    ],
    "agents": [
      "agents/"
    ],
    "hooks": [
      "hooks/hooks.json"
    ],
    "outputStyles": "output-styles/vais-default.md"
  },
  "scripts": {
    "test": "node --test tests/*.test.js tests/integration/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "lint": "eslint scripts/ lib/ hooks/ --max-warnings=0",
    "prepare-hooks": "git config core.hooksPath .hooks"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^6.1.7",
    "eslint": "^9.0.0",
    "react": "^19.2.5"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "claude-plugin",
    "ai-agents",
    "c-suite",
    "vais"
  ]
}
