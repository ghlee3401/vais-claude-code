{
  "_purpose": "REFERENCE STRUCTURE — harness engineering 최소 참조. basic/scripts/agent-tracker.js를 사용하며, 메인 플러그인의 hooks/hooks.json(scripts/agent-start.js + agent-stop.js 분리형)과 의도적으로 다름. basic/ 자체가 ${CLAUDE_PLUGIN_ROOT}로 사용될 때만 유효.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/bash-guard.js",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/doc-tracker.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/stop-handler.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/agent-tracker.js start ${AGENT_NAME:-unknown}",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/agent-tracker.js stop ${AGENT_NAME:-unknown} ${OUTCOME:-success}",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
