{
  "version": "0.18.1",
  "workflow": {
    "phases": ["plan", "design", "infra", "fe", "be", "qa", "report"],
    "phaseNames": {
      "plan": "기획",
      "design": "설계",
      "infra": "인프라",
      "fe": "프론트엔드",
      "be": "백엔드",
      "qa": "QA",
      "report": "보고서"
    },
    "docPaths": {
      "plan": "docs/01-plan/{feature}.md",
      "design": "docs/02-design/{feature}.md",
      "infra": "docs/03-infra/{feature}.md",
      "qa": "docs/04-qa/{feature}.md",
      "report": "docs/05-report/{feature}.md"
    }
  },
  "parallelGroups": {
    "implementation": ["fe", "be"]
  },
  "chaining": {
    "sequential": ":",
    "parallel": "+"
  },
  "gapAnalysis": {
    "matchThreshold": 90,
    "maxIterations": 5,
    "autoIterate": true
  },
  "qa": {
    "autoReview": true,
    "checklistRequired": true
  },
  "manager": {
    "enabled": true,
    "memory": {
      "path": ".vais/memory.json",
      "maxEntries": 500
    },
    "autoInvoke": ["auto", "fix"],
    "entryTypes": ["decision", "change", "feedback", "dependency", "debt", "error", "milestone"]
  },
  "team": {
    "enabled": true,
    "maxTeammates": 6,
    "agentTeam": {
      "name": "vais-dev-team",
      "description": "VAIS 6단계 개발 워크플로우 팀",
      "orchestrator": "manager",
      "roles": {
        "manager": { "model": "opus", "phases": ["*"], "delegates_to": ["designer", "infra-dev", "frontend-dev", "backend-dev", "qa"] },
        "designer": { "model": "sonnet", "phases": ["design"] },
        "infra-dev": { "model": "sonnet", "phases": ["infra"] },
        "frontend-dev": { "model": "sonnet", "phases": ["fe"] },
        "backend-dev": { "model": "sonnet", "phases": ["be"] },
        "qa": { "model": "sonnet", "phases": ["qa"] }
      },
      "routing": {
        "parallel": {
          "implementation": ["frontend-dev", "backend-dev"]
        }
      }
    }
  },
  "orchestration": {
    "gates": ["plan", "design", "infra", "fe"],
    "gateAction": "confirm",
    "gateChecklists": {
      "plan": [
        "피처 레지스트리 생성 완료",
        "데이터 모델 정의 완료",
        "기술 스택 선정 완료",
        "YAGNI 검증 통과"
      ],
      "design": [
        "모든 화면에 컴포넌트 명세 존재",
        "디자인 토큰 참조 명시",
        "화면 간 네비게이션 플로우 정의",
        "에러/로딩/빈 상태 정의",
        "Interface Contract 생성 완료"
      ],
      "infra": [
        "DB 스키마가 데이터 모델과 일치",
        "마이그레이션 파일 생성 완료",
        "환경 변수 템플릿 생성",
        "프로젝트 빌드 성공"
      ],
      "fe": [
        "빌드 성공",
        "FE/BE 모두 Interface Contract 참조",
        "피처 레지스트리 status 업데이트 완료"
      ]
    }
  },
  "conventions": {
    "referenceComment": {
      "description": "외부 사이트/문서를 참고하여 코드를 작성한 경우, 해당 코드 블록 위에 @see 주석을 추가한다",
      "format": "{commentChar} @see {URL}",
      "placement": "참고한 코드 블록 바로 위",
      "examples": {
        "js/ts": "// @see https://nextjs.org/docs/app/api-reference/functions/generate-metadata#twitter",
        "python": "# @see https://docs.python.org/3/library/asyncio.html",
        "html": "<!-- @see https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meta -->",
        "css": "/* @see https://tailwindcss.com/docs/customizing-colors */",
        "shell": "# @see https://www.gnu.org/software/bash/manual/bash.html#Pipelines"
      },
      "rules": [
        "참고한 URL 전체를 작성한다 (축약 금지)",
        "한 코드 블록에 여러 참고가 있으면 @see를 줄마다 하나씩 작성한다",
        "참고 코드 블록 바로 위에 작성한다 (빈 줄 없이)",
        "자명한 표준 라이브러리 사용은 @see 생략 가능"
      ]
    }
  },
  "featureNameValidation": {
    "pattern": "^[a-zA-Z0-9가-힣_-]+$",
    "maxLength": 100,
    "description": "허용: 한글, 영문, 숫자, -, _ (공백, 특수문자, 경로 문자 불가)"
  },
  "featureNameSuggestions": {
    "_description": "자주 쓰는 피처 이름 예시 (kebab-case 권장, 강제 아님)",
    "인증·사용자": [
      "login",
      "signup",
      "oauth",
      "user-profile",
      "my-page",
      "password-reset"
    ],
    "결제·커머스": [
      "payment",
      "cart",
      "checkout",
      "order-history",
      "wishlist",
      "coupon"
    ],
    "콘텐츠": [
      "feed",
      "post",
      "comment",
      "search",
      "notification",
      "bookmark"
    ],
    "소셜": [
      "chat",
      "follow",
      "share",
      "invite",
      "review"
    ],
    "관리·운영": [
      "dashboard",
      "settings",
      "admin-panel",
      "analytics"
    ]
  }
}
