{
  "version": "0.14.0",
  "workflow": {
    "phases": ["research", "plan", "ia", "wireframe", "design", "fe", "be", "check", "review"],
    "phaseNames": {
      "research": "조사·탐색",
      "plan": "기획",
      "ia": "IA 설계",
      "wireframe": "와이어프레임",
      "design": "설계 (UI+DB)",
      "fe": "프론트엔드",
      "be": "백엔드",
      "check": "Gap 분석",
      "review": "검토"
    },
    "docPaths": {
      "research": "docs/01-research/{feature}.md",
      "plan": "docs/02-plan/{feature}.md",
      "ia": "docs/03-ia/{feature}.md",
      "wireframe": "docs/04-wireframe/{feature}.md",
      "design": "docs/05-design/{feature}.md",
      "design-db": "docs/05-design/{feature}-db.md",
      "check": "docs/06-check/{feature}.md",
      "review": "docs/07-review/{feature}.md"
    }
  },
  "parallelGroups": {
    "design": ["ui-design", "db-design"],
    "implementation": ["fe", "be"]
  },
  "chaining": {
    "sequential": ":",
    "parallel": "+"
  },
  "gapAnalysis": {
    "matchThreshold": 90,
    "maxIterations": 5,
    "autoIterate": true
  },
  "review": {
    "autoReview": true,
    "checklistRequired": true
  },
  "manager": {
    "enabled": true,
    "memory": {
      "path": ".vais/memory.json",
      "maxEntries": 500
    },
    "autoInvoke": ["auto", "fix"],
    "entryTypes": ["decision", "change", "feedback", "dependency", "debt", "error", "milestone"]
  },
  "team": {
    "enabled": true,
    "maxTeammates": 6,
    "agentTeam": {
      "name": "vais-dev-team",
      "description": "VAIS 9단계 개발 워크플로우 팀",
      "orchestrator": "manager",
      "roles": {
        "manager": { "model": "opus", "phases": ["*"], "delegates_to": ["tech-lead"] },
        "tech-lead": { "model": "opus", "phases": ["research", "plan", "check", "review"], "delegates_to": ["designer", "frontend-dev", "backend-dev", "reviewer"] },
        "designer": { "model": "sonnet", "phases": ["ia", "wireframe", "design"] },
        "frontend-dev": { "model": "sonnet", "phases": ["fe"] },
        "backend-dev": { "model": "sonnet", "phases": ["design-db", "be"] },
        "reviewer": { "model": "sonnet", "phases": ["check", "review"] }
      },
      "routing": {
        "parallel": {
          "design": ["designer", "backend-dev"],
          "implementation": ["frontend-dev", "backend-dev"]
        },
        "council": {
          "review": ["reviewer", "tech-lead"]
        }
      }
    }
  },
  "orchestration": {
    "gates": ["plan", "fe"],
    "gateAction": "confirm"
  },
  "featureNameValidation": {
    "pattern": "^[a-zA-Z0-9가-힣_-]+$",
    "maxLength": 100,
    "description": "허용: 한글, 영문, 숫자, -, _ (공백, 특수문자, 경로 문자 불가)"
  },
  "featureNameSuggestions": {
    "_description": "자주 쓰는 피처 이름 예시 (kebab-case 권장, 강제 아님)",
    "인증·사용자": [
      "login",
      "signup",
      "oauth",
      "user-profile",
      "my-page",
      "password-reset"
    ],
    "결제·커머스": [
      "payment",
      "cart",
      "checkout",
      "order-history",
      "wishlist",
      "coupon"
    ],
    "콘텐츠": [
      "feed",
      "post",
      "comment",
      "search",
      "notification",
      "bookmark"
    ],
    "소셜": [
      "chat",
      "follow",
      "share",
      "invite",
      "review"
    ],
    "관리·운영": [
      "dashboard",
      "settings",
      "admin-panel",
      "analytics"
    ]
  }
}
