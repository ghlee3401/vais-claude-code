{
  "version": "2.0.0",
  "description": "vais event-log.jsonl 이벤트 스키마 문서. MCP 서버 + 대시보드 소비용",
  "events": {
    "session_start": {
      "description": "새 피처 개발 세션 시작",
      "payload": ["feature", "c_suite"],
      "required": ["feature"]
    },
    "session_end": {
      "description": "세션 종료",
      "payload": ["feature", "outcome"],
      "required": ["feature"]
    },
    "agent_start": {
      "description": "에이전트 실행 시작",
      "payload": ["role", "phase", "task"],
      "required": ["role", "phase"]
    },
    "agent_stop": {
      "description": "에이전트 완료/실패",
      "payload": ["role", "outcome", "doc"],
      "required": ["role", "outcome"]
    },
    "phase_transition": {
      "description": "단계 전환 (plan→design 등)",
      "payload": ["from", "to", "feature"],
      "required": ["from", "to", "feature"]
    },
    "gate_check": {
      "description": "Gate 판정",
      "payload": ["gate", "result", "items"],
      "required": ["gate", "result"]
    },
    "decision": {
      "description": "C-Suite 결정 기록",
      "payload": ["role", "type", "choice", "rationale"],
      "required": ["role", "type", "choice"]
    },
    "error": {
      "description": "에러 발생",
      "payload": ["role", "code", "message"],
      "required": ["role", "message"]
    }
  }
}
